# Keystore properties for release signing
# Copy this file to keystore.properties at project root (do NOT commit keystore.properties)
# or set equivalent environment variables in CI:
# RELEASE_STORE_FILE, RELEASE_STORE_PASSWORD, RELEASE_KEY_ALIAS, RELEASE_KEY_PASSWORD

storeFile=/absolute/path/to/arm-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=armkey
keyPassword=YOUR_KEY_PASSWORD
